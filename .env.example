# docker-compose.prod.yml 运行时环境变量
# 复制为 .env 后填写真实值。.env 已在 gitignore，不会进仓库
#
# 生成强随机值:
#   openssl rand -base64 32   # POSTGRES_PASSWORD
#   openssl rand -base64 48   # JWT_SECRET

# ============================================================
# Postgres（容器内服务，仅 docker 内网可访问）
# ============================================================
POSTGRES_USER=admin
POSTGRES_PASSWORD=REPLACE_ME_STRONG_PASSWORD
POSTGRES_DB=energybot

# ============================================================
# Nest API
# ============================================================
# DATABASE_URL 由 compose 拼装后注入，这里不配
# JWT 签发密钥，对应 nest-api 的 ConfigEnum.SECRET
JWT_SECRET=REPLACE_ME_48_CHARS_RANDOM

# ============================================================
# Go Bot —— 必填
# ============================================================
TELEGRAM_BOT_TOKEN=REPLACE_ME
TRON_API_BASE_URL=https://api.trongrid.io
TRON_API_KEY=REPLACE_ME
PLATFORM_RECEIVE_ADDRESS=REPLACE_ME

# 能量供应商：justlend | catfee
ENERGY_PROVIDER=justlend

# JustLend（ENERGY_PROVIDER=justlend 时必填）
JUSTLEND_CONTRACT_ADDRESS=REPLACE_ME
JUSTLEND_PAYER_PRIVATE_KEY=REPLACE_ME

# CatFee（ENERGY_PROVIDER=catfee 时必填；否则留空即可）
CATFEE_ENVIRONMENT=nile
CATFEE_PROD_API_KEY=
CATFEE_PROD_API_SECRET=
CATFEE_NILE_API_KEY=
CATFEE_NILE_API_SECRET=

# ============================================================
# 暴露端口 —— IP 直接暴露模式
# ============================================================
# ui nginx 对外端口（nginx 内部反代 /api/ 到 nest-api）
UI_PORT=80

# ============================================================
# 镜像 tag —— 由 CI 或部署脚本注入，默认 latest
# ============================================================
IMAGE_TAG=latest
