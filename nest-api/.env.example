# Nest API 运行时配置
# 复制为 .env.production（或通过 Docker 环境变量注入生产环境）
# 本地开发可复制为 .env.development
#
# 注意：.env / .env.* 已在根目录 .gitignore 中拦截，不会进仓库

# --- 数据库 ---
# 生产格式: postgresql://USER:PASSWORD@HOST:PORT/DB?schema=public
# 生产环境中 HOST 一般为 docker 服务名 postgres
DATABASE_URL="postgresql://admin:REPLACE_ME@postgres:5432/energybot?schema=public"

# --- JWT ---
# 用于签发和校验登录 token，定义在 src/enum/config.enum.ts (ConfigEnum.SECRET)
# 生成命令: openssl rand -base64 48
# ⚠️ 每次部署新环境都应重新生成，不要复用旧值
SECRET=REPLACE_ME_WITH_STRONG_RANDOM_48_CHARS

# --- 运行模式 ---
# NODE_ENV 会影响 ConfigModule 读取的文件：.env.${NODE_ENV} > .env
NODE_ENV=production
# main.ts 中默认回退 3001；保持一致
PORT=3001

# --- License 秘钥加密主密钥（子系统 A）---
# 用 AES-256-GCM 加密存储客户 license secret（secretCipher 列）
# 必须是 base64 编码的 32 字节随机数，生成命令: openssl rand -base64 32
# ⚠️ 一旦生产环境使用后丢失此密钥，所有历史 license secret 将无法解密
#    → 必须备份（如：1Password / 阿里云 KMS / 离线金库）
# ⚠️ 轮换此密钥需要走离线迁移流程：用旧密钥解出所有 secretCipher，再用新密钥加密后写回
LICENSE_SECRET_ENC_KEY=REPLACE_ME_WITH_openssl_rand_base64_32
