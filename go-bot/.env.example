# Go Bot 运行时配置
# 复制为 .env 或通过 Docker 环境变量注入
# 变量定义与校验见 internal/config/config.go
#
# 注意：.env / .env.* 已在根目录 .gitignore 中拦截，不会进仓库

# ============================================================
# 必填 —— 所有部署都需要
# ============================================================

# --- 数据库 ---
# 和 nest-api 共享同一个业务库（见 README.md）
# 生产格式: postgresql://USER:PASSWORD@HOST:PORT/DB?schema=public
DATABASE_URL="postgresql://admin:REPLACE_ME@postgres:5432/energybot?schema=public"

# --- Telegram ---
# 从 @BotFather 获取
TELEGRAM_BOT_TOKEN=REPLACE_ME

# --- TRON 链 ---
# 主网: https://api.trongrid.io
# 测试网: https://api.nileex.io
TRON_API_BASE_URL=https://api.trongrid.io
# 从 https://www.trongrid.io/ 控制台申请
TRON_API_KEY=REPLACE_ME

# --- 平台收款地址 ---
# 用户付款进入的 TRON 地址（Base58 格式，T 开头）
PLATFORM_RECEIVE_ADDRESS=REPLACE_ME

# ============================================================
# 能量供应商 —— 按 ENERGY_PROVIDER 选一组填
# ============================================================

# 可选值：justlend | catfee，默认 justlend
ENERGY_PROVIDER=justlend

# --- JustLend（ENERGY_PROVIDER=justlend 时必填） ---
JUSTLEND_CONTRACT_ADDRESS=REPLACE_ME
# ⚠️ 高度敏感，服务器本地只读权限 0600
JUSTLEND_PAYER_PRIVATE_KEY=REPLACE_ME

# --- CatFee（ENERGY_PROVIDER=catfee 时必填） ---
# 环境：nile（测试） | prod（生产）
CATFEE_ENVIRONMENT=nile
# 生产环境密钥
CATFEE_PROD_API_BASE_URL=https://api.catfee.io
CATFEE_PROD_API_KEY=
CATFEE_PROD_API_SECRET=
# 测试环境密钥
CATFEE_NILE_API_BASE_URL=https://nile.catfee.io
CATFEE_NILE_API_KEY=
CATFEE_NILE_API_SECRET=
# 订单到账后自动激活，true/false
CATFEE_AUTO_ACTIVATE=true

# ============================================================
# 可选 —— 不填走默认值
# ============================================================

# 订单待支付 TTL，Go time.Duration 语法（默认 10m）
ORDER_PAYMENT_TTL=10m
# 能量租赁 TTL（默认 1h）
ENERGY_RENTAL_TTL=1h
# Telegram 长轮询间隔（默认 2s）
TELEGRAM_POLLING_INTERVAL=2s
# 后台 worker 节拍（默认 1m）
WORKER_INTERVAL=1m
# 平台最低 TRX 储备（Sun 单位，默认 0）
MIN_TRX_RESERVE_SUN=0
# 机器人总开关：enabled | disabled（默认 enabled）
BOT_STATUS=enabled
